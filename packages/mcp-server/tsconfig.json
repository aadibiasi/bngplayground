{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": [
      "ES2022"
    ],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": false,
    "outDir": "dist",
    "declaration": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "baseUrl": ".",
    "paths": {
      "@grammar/*": ["../../services/grammar/*"]
    }
  },
  "include": [
    "src/**/*",
    "../../services/grammar/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}